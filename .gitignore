# ========================
# DecideWise — .gitignore
# ========================

# -------
# Node.js
# -------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# -----
# Build
# -----
dist/
dist-ssr/
build/
out/
.output/

# -----
# Vite
# -----
*.local
.vite/

# ----------
# TypeScript
# ----------
*.tsbuildinfo

# ---------
# Env files
# ---------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# -------
# Editors
# -------

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist

# Emacs
*~
\#*\#
.\#*

# -------
# OS Files
# -------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----
# Logs
# -----
logs/
*.log
lerna-debug.log*

# ------
# Cache
# ------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# --------
# Testing
# --------
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# -------
# Backend (if applicable)
# -------
uploads/
*.sqlite
*.db
*.db-shm
*.db-wal

# --------
# Optional
# --------
storybook-static/
.chromatic/
